{
  "name": "app-poleron",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "set NODE_OPTIONS=--no-experimental-strip-types && expo start",
    "android": "set NODE_OPTIONS=--no-experimental-strip-types && expo run:android",
    "ios": "set NODE_OPTIONS=--no-experimental-strip-types && expo run:ios",
    "web": "set NODE_OPTIONS=--no-experimental-strip-types && expo start --web",
    "build-apk": "set NODE_OPTIONS=--no-experimental-strip-types && eas build -p android --profile preview",
    "local-apk": "cd android && gradlew.bat assembleRelease",
    "local-apk-full": "scripts/build-full-apk.bat"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "babel-preset-expo": "~12.0.7",
    "buffer": "^6.0.3",
    "expo": "52.0.49",
    "expo-constants": "~17.0.7",
    "expo-device": "~7.0.3",
    "expo-file-system": "~18.0.7",
    "expo-font": "~13.0.4",
    "expo-notifications": "~0.29.14",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "firebase": "^10.0.0",
    "lucide-react-native": "^1.7.0",
    "process": "^0.11.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5",
    "readable-stream": "^4.7.0",
    "stream-browserify": "^3.0.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "^18.3.28",
    "@types/react-native": "^0.72.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
